<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8">
    <title>{{ dossier.title }}</title>
    <style>{{ css_text }}</style>
  </head>
  <body>
    <section class="page cover">
      {% if dossier.hero_image_url %}<img class="cover-image" src="{{ dossier.hero_image_url }}" alt="Hero">{% endif %}
      <div class="cover-shade"></div>
      <div class="cover-copy">
        <div class="wordmark">PropertyQuarry</div>
        <div class="eyebrow">{{ dossier.packet_kind.value.replace('_', ' ') }} · {{ dossier.privacy_mode.value.replace('_', ' ') }}</div>
        <h1>{{ dossier.title }}</h1>
        <p class="cover-lead">{{ dossier.fit_summary or dossier.recommendation }}</p>
        <div class="cover-stats">
          {% for card in dossier.fact_cards[:4] %}
          <div class="cover-stat">
            <div class="cover-stat-label">{{ card.label }}</div>
            <div class="cover-stat-value">{{ card.value }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    {% if dossier.appendix_mode %}
    <section class="page">
      <div class="page-inner">
        <div class="appendix-kicker">Viewing Appendix</div>
        <div class="decision-grid">
          <div class="decision-panel">
            <div class="appendix-label">
              {% if dossier.source_pdf_filename %}
              Appendix to uploaded PDF: {{ dossier.source_pdf_filename }}
              {% else %}
              Appendix to uploaded property PDF
              {% endif %}
            </div>
            <h2>{{ dossier.title }}</h2>
            {% if dossier.property_narrative %}
            {% for line in dossier.property_narrative[:2] %}
            <p class="decision-copy">{{ line }}</p>
            {% endfor %}
            {% else %}
            <p class="decision-copy">PropertyQuarry reviewed the uploaded source PDF and generated the decision, research, and media follow-up artifacts.</p>
            {% endif %}
            <div class="decision-pills">
              <span class="pill">{{ dossier.privacy_mode.value.replace('_', ' ') }}</span>
              {% if dossier.confidence_label %}<span class="pill">Confidence · {{ dossier.confidence_label }}</span>{% endif %}
            </div>
          </div>
          <div class="action-rail">
            <div class="action-copy">
              <h3>Artifact links</h3>
              <p>Use these actions to inspect the live visual layer and continue the owner review without exposing raw source internals.</p>
            </div>
            {% if dossier.tour_url %}<a class="cta" href="{{ dossier.tour_url }}">Open 3D control</a>{% endif %}
            {% if dossier.flythrough_url %}<a class="cta cta-secondary" href="{{ dossier.flythrough_url }}">Play fly-through</a>{% endif %}
            {% if dossier.review_url %}<a class="cta cta-secondary" href="{{ dossier.review_url }}">Open dossier</a>{% endif %}
          </div>
        </div>
        <div class="two-col" style="margin-top:28px;">
          <div class="panel">
            <h3 class="appendix-subheading">Deep research results</h3>
            <ul>
              {% for line in dossier.appendix_research_lines[:6] %}
              <li>{{ line }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="panel">
            <h3 class="appendix-subheading">Most useful next checks</h3>
            <ul>
              {% for line in dossier.agent_questions[:4] %}
              <li>{{ line }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </section>
    {% else %}

    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Executive decision</div>
        <div class="decision-grid">
          <div class="decision-panel">
            <div class="decision-label">Current read</div>
            <h2>{{ dossier.recommendation }}</h2>
            <div class="decision-pills">
              <span class="pill">Confidence · {{ dossier.confidence_label }}</span>
              {% if dossier.fit_summary %}<span class="pill">{{ dossier.fit_summary }}</span>{% endif %}
            </div>
            {% if dossier.compare_reason %}<p class="decision-copy">{{ dossier.compare_reason }}</p>{% endif %}
            {% if dossier.next_action %}<p class="decision-next"><strong>Next action:</strong> {{ dossier.next_action }}</p>{% endif %}
          </div>
          <div class="decision-sidebar">
            <div class="list-block">
              <h3>Why it matches</h3>
              <ul>{% for line in dossier.why_match %}<li>{{ line }}</li>{% endfor %}</ul>
            </div>
            <div class="list-block">
              <h3>Why it may fail</h3>
              <ul>{% for line in dossier.why_fail %}<li>{{ line }}</li>{% endfor %}</ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="page image-spread">
      <div class="page-inner">
        <div class="section-kicker">Property portrait</div>
        <div class="image-layout">
          <div class="image-main">
            {% if dossier.portrait_image_url %}
            <img class="gallery-hero" src="{{ dossier.portrait_image_url }}" alt="Property portrait">
            {% elif dossier.hero_image_url %}
            <img class="gallery-hero" src="{{ dossier.hero_image_url }}" alt="Property image">
            {% endif %}
          </div>
          <div class="image-stack">
            {% if dossier.property_image_url and dossier.property_image_url != dossier.portrait_image_url %}
            <img class="stack-image" src="{{ dossier.property_image_url }}" alt="Property still">
            {% endif %}
            {% for image_url in dossier.detail_gallery_urls[:3] %}
            <img class="stack-image" src="{{ image_url }}" alt="Property detail {{ loop.index }}">
            {% endfor %}
          </div>
        </div>
        <div class="narrative-grid">
          <div class="narrative-block">
            {% for line in dossier.property_narrative[:5] %}
            <p>{{ line }}</p>
            {% endfor %}
          </div>
          <div class="fact-grid">
            {% for card in dossier.fact_cards %}
            <article class="fact-card">
              <div class="fact-label">{{ card.label }}</div>
              <div class="fact-value">{{ card.value }}</div>
            </article>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    {% if dossier.scene_image_url %}
    <section class="page image-spread">
      <div class="page-inner">
        <div class="section-kicker">Scene render</div>
        <div class="image-layout single-visual-layout">
          <div class="image-main">
            <img class="gallery-hero" src="{{ dossier.scene_image_url }}" alt="Scene render">
          </div>
          <div class="panel">
            <h3>Property-fitting visual simulation</h3>
            <p>{{ dossier.scene_summary or payload.magic_fit_scene.summary or "This render is generated to depict a believable scene inside the property, not a generic stock mood image." }}</p>
            <ul>
              <li>Scene type: {{ (payload.magic_fit_scene.scene_type or 'scene')|replace('_', ' ') }}</li>
              <li>Provider-guided property scene, not source evidence</li>
              <li>Used to orient the decision before the full media review</li>
            </ul>
            {% if payload.magic_fit_scene.reference_urls %}
            <div class="reference-strip">
              {% for image_url in payload.magic_fit_scene.reference_urls[:3] %}
              <img class="reference-thumb" src="{{ image_url }}" alt="Personal reference {{ loop.index }}">
              {% endfor %}
            </div>
            <p class="reference-note">Private references stay in the protected packet path and only guide this scene softly.</p>
            {% endif %}
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    {% if payload.personal_reference_urls %}
    <section class="page image-spread">
      <div class="page-inner">
        <div class="section-kicker">Personal references</div>
        <div class="panel">
          <h3>Private reference photos</h3>
          <p>Diese privaten Referenzbilder gehören nur in diesen geschützten Packet-Pfad. Sie dienen dazu, das Objekt im familiären Kontext schneller einzuordnen.</p>
          <div class="reference-strip">
            {% for image_url in payload.personal_reference_urls[:3] %}
            <img class="reference-thumb" src="{{ image_url }}" alt="Personal reference {{ loop.index }}">
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    {% if payload.diorama_scene and payload.diorama_scene.image_url %}
    <section class="page image-spread">
      <div class="page-inner">
        <div class="section-kicker">Diorama preview</div>
        <div class="image-layout single-visual-layout">
          <div class="image-main">
            <img class="gallery-hero" src="{{ payload.diorama_scene.image_url }}" alt="Diorama preview">
          </div>
          <div class="panel">
            <h3>White-label spatial preview</h3>
            <p>{{ payload.diorama_scene.summary or "A stylised preview of the route, layout, and overall living feel of the flat." }}</p>
            <ul>
              <li>Purpose: fast visual orientation before the full 3D surface</li>
              <li>Type: generated preview, not source evidence</li>
              <li>Linked to the hosted 3D tour and flythrough lane</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    {% if dossier.editorial_sections %}
    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Editorial narrative</div>
        <div class="two-col">
          {% for section in dossier.editorial_sections[:4] %}
          <div class="panel">
            <h3>{{ section.title }}</h3>
            {% if section.body %}<p>{{ section.body }}</p>{% endif %}
            {% if section.bullets %}
            <ul>{% for line in section.bullets[:5] %}<li>{{ line }}</li>{% endfor %}</ul>
            {% endif %}
            {% if section.cta %}<p class="decision-next"><strong>Next action:</strong> {{ section.cta }}</p>{% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
    {% endif %}

    {% if payload.route_context and payload.route_context.rows %}
    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Route context</div>
        <div class="two-col">
          <div class="panel">
            <h3>{{ payload.route_context.provider or "AvoMap" }} route read</h3>
            <p>These routes are prepared from the property origin so the packet shows how the place behaves in everyday movement, not just on a district map.</p>
            <ul>
              {% for row in payload.route_context.rows %}
              <li><strong>{{ row.label }}</strong>{% if row.detail %} · {{ row.detail }}{% endif %}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="action-rail">
            <div class="action-copy">
              <h3>Open routes</h3>
              <p>Each link opens the route directly from the property to the selected destination or daily-life target.</p>
            </div>
            {% for row in payload.route_context.rows %}
            <a class="cta{% if not loop.first %} cta-secondary{% endif %}" href="{{ row.href }}">{{ row.label }}</a>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Location and daily-life radius</div>
        <div class="two-col">
          <div class="panel">
            <h3>Daily-life read</h3>
            <ul>{% for line in dossier.daily_life %}<li>{{ line }}</li>{% endfor %}</ul>
          </div>
          <div class="panel">
            <h3>Family route and school independence</h3>
            <ul>{% for line in dossier.family_route %}<li>{{ line }}</li>{% endfor %}</ul>
          </div>
        </div>
      </div>
    </section>

    {% if payload.dadan_context %}
    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Video feedback follow-up</div>
        <div class="two-col">
          <div class="panel">
            <h3>Dadan follow-up state</h3>
            <ul>
              <li>Mode: {{ payload.dadan_context.mode or "manual" }}</li>
              <li>Request status: {{ payload.dadan_context.request_status or (payload.dadan_context.enabled and "available" or "not configured") }}</li>
              {% if payload.dadan_context.request_kind %}<li>Request kind: {{ payload.dadan_context.request_kind|replace('_', ' ') }}</li>{% endif %}
              {% if payload.dadan_context.response_status %}<li>Latest response: {{ payload.dadan_context.response_status|replace('_', ' ') }}</li>{% endif %}
              {% if payload.dadan_context.submitted_at %}<li>Submitted: {{ payload.dadan_context.submitted_at }}</li>{% endif %}
            </ul>
          </div>
          <div class="action-rail">
            <div class="action-copy">
              <h3>Collect video proof</h3>
              <p>Use this lane for agent walk-through answers or owner-reviewed follow-up when documents or claims are still unresolved.</p>
            </div>
            {% if payload.dadan_context.request_url %}
            <a class="cta" href="{{ payload.dadan_context.request_url }}">Open Dadan request</a>
            {% endif %}
            {% if payload.dadan_context.recording_url %}
            <a class="cta cta-secondary" href="{{ payload.dadan_context.recording_url }}">Open latest response</a>
            {% endif %}
            {% if dossier.review_url %}
            <a class="cta cta-secondary" href="{{ dossier.review_url }}">Open property page</a>
            {% endif %}
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Hosted 360 and media</div>
        <div class="two-col media-grid">
          <div class="media-stage">
            {% if dossier.floorplan_urls %}
            <img class="floorplan-hero" src="{{ dossier.floorplan_urls[0] }}" alt="Floorplan">
            {% elif dossier.gallery_urls %}
            <img class="floorplan-hero" src="{{ dossier.gallery_urls[0] }}" alt="Property image">
            {% endif %}
          </div>
          <div class="action-rail">
            <div class="action-copy">
              <h3>Open the full property page</h3>
              <p>Die digitale Medienebene führt direkt in die 3D-Tour, das Flythrough-Video und den PropertyQuarry-Pfad, statt nur rohe Quellenlinks zu sammeln.</p>
            </div>
            {% if dossier.tour_url %}<a class="cta" href="{{ dossier.tour_url }}">Open 3D reconstruction</a>{% endif %}
            {% if dossier.flythrough_url %}<a class="cta" href="{{ dossier.flythrough_url }}">Play flythrough</a>{% endif %}
            {% if dossier.map_url %}<a class="cta cta-secondary" href="{{ dossier.map_url }}">Open Google Maps</a>{% endif %}
            {% if dossier.review_url %}<a class="cta cta-secondary" href="{{ dossier.review_url }}">Open property page</a>{% endif %}
          </div>
        </div>
      </div>
    </section>

    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Risk register and next proof</div>
        <div class="two-col">
          <div class="panel">
            <h3>Risk register</h3>
            <ul class="risk-list">{% for line in dossier.risk_register %}<li>{{ line }}</li>{% endfor %}</ul>
          </div>
          <div class="panel">
            <h3>Agent brief</h3>
            <ul>{% for line in dossier.agent_questions %}<li>{{ line }}</li>{% endfor %}</ul>
          </div>
        </div>
      </div>
    </section>

    {% if dossier.comparison_rows %}
    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Comparison snapshot</div>
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Angebot</th>
              <th>Preis</th>
              <th>Fläche</th>
              <th>Zimmer</th>
              <th>Read</th>
            </tr>
          </thead>
          <tbody>
            {% for row in dossier.comparison_rows %}
            <tr>
              <td>
                <div>{{ row.title or row.label }}</div>
                {% if row.source_label %}<div class="muted">{{ row.source_label }}</div>{% endif %}
                {% if row.review_url or row.tour_url or row.map_url or row.property_url %}
                <div class="muted">
                  {% if row.review_url %}<a href="{{ row.review_url }}">Review</a>{% endif %}
                  {% if row.tour_url %} · <a href="{{ row.tour_url }}">360</a>{% endif %}
                  {% if row.map_url %} · <a href="{{ row.map_url }}">Map</a>{% endif %}
                  {% if row.property_url %} · <a href="{{ row.property_url }}">Listing</a>{% endif %}
                </div>
                {% endif %}
              </td>
              <td>{{ row.price or "Offen" }}</td>
              <td>{{ row.area or row.area_sqm or "Offen" }}</td>
              <td>{{ row.rooms or "Offen" }}</td>
              <td>{{ row.recommendation or row.fit_summary or "Review" }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
    {% endif %}

    {% if dossier.investment_lines %}
    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Investment read</div>
        <div class="panel">
          <ul>{% for line in dossier.investment_lines %}<li>{{ line }}</li>{% endfor %}</ul>
        </div>
      </div>
    </section>
    {% endif %}

    <section class="page">
      <div class="page-inner">
        <div class="section-kicker">Provenance, privacy, and legal notice</div>
        <div class="panel">
          <ul>{% for line in dossier.provenance_lines %}<li>{{ line }}</li>{% endfor %}</ul>
          {% if dossier.neuronwriter_status %}
          <ul>
            <li>NeuronWriter guidance: {{ dossier.neuronwriter_status }}{% if dossier.neuronwriter_reason %} · {{ dossier.neuronwriter_reason }}{% endif %}</li>
            {% for line in dossier.neuronwriter_questions[:3] %}<li>Question cue: {{ line }}</li>{% endfor %}
          </ul>
          {% endif %}
        </div>
        <p class="legal">This packet supports decision-making and does not replace legal, technical, surveying, tax, or investment advice.</p>
      </div>
    </section>
    {% endif %}
  </body>
</html>
