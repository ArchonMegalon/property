FROM python:3.12-slim@sha256:57cd7c3a7a273101a6485ba99423ee568157882804b1124b4dd04266317710de AS prepared

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    adduser --system --uid 10001 --group --home /home/ea --shell /bin/sh ea

WORKDIR /app

COPY ea/requirements.txt /app/requirements.txt
COPY ea/requirements.lock /app/requirements.lock

RUN python -m pip install --no-cache-dir --upgrade pip==26.1.2 && \
    pip install --no-cache-dir -r requirements.txt -c requirements.lock

RUN mkdir -p /app/scripts /app/docs /data/artifacts /data/public_property_tours /data/provider-ledger /home/ea
COPY scripts/willhaben_property_packet.py /app/scripts/willhaben_property_packet.py
COPY scripts/property_magicfit_env.py /app/scripts/property_magicfit_env.py
COPY scripts/mootion_movie_worker.py /app/scripts/mootion_movie_worker.py
COPY scripts/render_magicfit_property_flythrough.py /app/scripts/render_magicfit_property_flythrough.py
COPY scripts/render_onemin_property_i2v_segment.py /app/scripts/render_onemin_property_i2v_segment.py
COPY scripts/render_omagic_property_model_walkthrough.py /app/scripts/render_omagic_property_model_walkthrough.py
COPY scripts/render_magicai_model_upload_adapter.py /app/scripts/render_magicai_model_upload_adapter.py
COPY scripts/property_scene_video_readiness_report.py /app/scripts/property_scene_video_readiness_report.py
COPY scripts/property_scene_video_runtime_status.py /app/scripts/property_scene_video_runtime_status.py
COPY scripts/propertyquarry_postgres_browser_bootstrap.py /app/scripts/propertyquarry_postgres_browser_bootstrap.py
COPY scripts/verify_property_scene_video_readiness.py /app/scripts/verify_property_scene_video_readiness.py
COPY scripts/materialize_scene_video_provider_refresh_packet.py /app/scripts/materialize_scene_video_provider_refresh_packet.py
COPY scripts/verify_scene_video_provider_refresh_packet.py /app/scripts/verify_scene_video_provider_refresh_packet.py
COPY scripts/merge_scene_video_provider_accounts_env.py /app/scripts/merge_scene_video_provider_accounts_env.py
COPY scripts/import_3dvista_export.py /app/scripts/import_3dvista_export.py
COPY scripts/import_pano2vr_export.py /app/scripts/import_pano2vr_export.py
COPY scripts/import_krpano_walkable_scene.py /app/scripts/import_krpano_walkable_scene.py
COPY scripts/import_property_tour_exports.py /app/scripts/import_property_tour_exports.py
COPY scripts/attach_provider_tour_layer.py /app/scripts/attach_provider_tour_layer.py
COPY scripts/discover_property_tour_exports.py /app/scripts/discover_property_tour_exports.py
COPY scripts/materialize_property_tour_export_manifest.py /app/scripts/materialize_property_tour_export_manifest.py
COPY scripts/property_tour_runtime_paths.py /app/scripts/property_tour_runtime_paths.py
COPY scripts/generate_property_reconstruction.py /app/scripts/generate_property_reconstruction.py
COPY scripts/import_magicfit_walkthrough.py /app/scripts/import_magicfit_walkthrough.py
COPY scripts/verify_property_tour_controls.py /app/scripts/verify_property_tour_controls.py
COPY scripts/property_tour_3dvista_provenance.py /app/scripts/property_tour_3dvista_provenance.py
COPY scripts/intake_3dvista_gold_artifact.py /app/scripts/intake_3dvista_gold_artifact.py
COPY vendor/three /app/vendor/three
COPY ea/app /app/app
COPY docs/PROPERTYQUARRY_RELEASE_MANIFEST.md /app/docs/PROPERTYQUARRY_RELEASE_MANIFEST.md
COPY --chmod=0555 ea/property_web_entrypoint.py /usr/local/libexec/property_web_entrypoint.py
COPY --chmod=0555 ea/property_web_elf_validator.py /usr/local/libexec/property_web_elf_validator.py
COPY LTDs.md /app/LTDs.md

RUN set -eu; \
    mkdir -p /data/artifacts /data/public_property_tours /data/provider-ledger /home/ea; \
    chown -R ea:ea /app /data /home/ea

USER 0:0

RUN set -eux; \
    export DEBIAN_FRONTEND=noninteractive; \
    apt-get clean; \
    dpkg-query -W -f='${db:Status-Status}\t${Package}\n' \
        > /tmp/property-web-packages.before; \
    apt-get purge --yes --allow-remove-essential --no-auto-remove \
        gzip \
        perl-base \
        bsdutils \
        libblkid1 \
        liblastlog2-2 \
        libmount1 \
        libsmartcols1 \
        libuuid1 \
        login \
        mount \
        util-linux; \
    rm -rf /var/lib/apt/lists/*; \
    test -s /var/lib/dpkg/status; \
    audit_output="$(dpkg --audit)"; \
    test -z "${audit_output}"; \
    dpkg-query -W -f='${db:Status-Status}\t${Package}\n' \
        > /tmp/property-web-packages.after; \
    python -c 'from pathlib import Path; load=lambda name: {row[1] for line in Path(name).read_text(encoding="utf-8").splitlines() if len(row := line.split("\t")) == 2 and row[0] == "installed"}; before=load("/tmp/property-web-packages.before"); after=load("/tmp/property-web-packages.after"); removed=sorted(before-after); added=sorted(after-before); expected=sorted({"gzip", "bsdutils", "libblkid1", "liblastlog2-2", "libmount1", "libsmartcols1", "libuuid1", "login", "mount", "perl-base", "util-linux"}); invalid=removed != expected or bool(added); print("unexpected package delta: removed=" + repr(removed) + " added=" + repr(added), file=__import__("sys").stderr) if invalid else None; raise SystemExit(invalid)'; \
    dpkg-query -W \
        -f='${db:Status-Status}\t${source:Package}\t${binary:Package}\n' \
        | python -c 'import sys; rows=[line.rstrip("\n").split("\t") for line in sys.stdin]; bad=[row for row in rows if len(row) >= 3 and row[0] == "installed" and ((row[1].split()[0] if row[1].split() else row[2].split(":", 1)[0]) in {"gzip", "perl", "util-linux"})]; print("\n".join("\t".join(row) for row in bad), file=sys.stderr) if bad else None; raise SystemExit(bool(bad))'; \
    python -I -S -c 'import sysconfig; from pathlib import Path; root=Path(sysconfig.get_config_var("DESTSHARED")); modules=("_uuid", "_tkinter"); matches={module: sorted(root.glob(f"{module}.*")) for module in modules}; assert all(len(paths) == 1 for paths in matches.values()), matches; assert all(paths[0].is_file() and not paths[0].is_symlink() for paths in matches.values()), matches; [paths[0].unlink() for paths in matches.values()]'; \
    python -I -S -c 'import importlib.util, uuid; assert importlib.util.find_spec("_uuid") is None; assert importlib.util.find_spec("_tkinter") is None; assert uuid.uuid1().version == 1; assert uuid.uuid4().version == 4'; \
    python -I -S /usr/local/libexec/property_web_elf_validator.py; \
    rm -f /usr/local/libexec/property_web_elf_validator.py; \
    rm -f /tmp/property-web-packages.before /tmp/property-web-packages.after; \
    ! command -v gzip; \
    ! command -v gunzip; \
    ! command -v perl; \
    ! command -v runuser

FROM scratch AS runtime

COPY --from=prepared / /

ENV PATH=/usr/local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    LANG=C.UTF-8 \
    GPG_KEY=7169605F62C751356D054A26A821E680E5FA6305 \
    PYTHON_VERSION=3.12.13 \
    PYTHON_SHA256=c08bc65a81971c1dd5783182826503369466c7e67374d1646519adf05207b684 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

USER 10001:10001

HEALTHCHECK --interval=30s --timeout=15s --start-period=30s --retries=5 \
  CMD ["/bin/sh", "-ec", "role=${EA_ROLE:-api}; case \"$role\" in worker|scheduler|render-tools) exit 0 ;; *) exec /usr/local/bin/python -c 'import http.client; connection=http.client.HTTPConnection(\"127.0.0.1\",8090,timeout=10); connection.request(\"GET\",\"/health/live\"); response=connection.getresponse(); raise SystemExit(0 if response.status == 200 else 1)' ;; esac"]

ENTRYPOINT ["/usr/local/bin/python", "-I", "-S", "/usr/local/libexec/property_web_entrypoint.py"]
CMD ["/usr/local/bin/python", "-m", "app.runner"]
