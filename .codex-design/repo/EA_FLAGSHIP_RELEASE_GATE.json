      "privacy_security_and_regional_controls",
      "reliability_capacity_and_operations",
      "protected_live_launch_authority"
    ],
    "accessibility_standard": "WCAG 2.2 Level AA",
    "performance_field_thresholds": {
      "lcp_p75_ms_max": 2500,
      "inp_p75_ms_max": 200,
      "cls_p75_max": 0.1
    },
    "market_envelope": {
      "authority": "_completion/property_global_market_envelope/release-gate.json",
      "required_status_for_launch": "pass",
      "only_full_e2e_markets_are_launch_supported": true,
