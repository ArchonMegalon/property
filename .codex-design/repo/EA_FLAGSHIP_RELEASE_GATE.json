  },
  "global_launch_contract": {
    "schema": "propertyquarry.global_flagship_goal.v1",
    "claim": "global_grade_with_explicit_market_envelope",
    "universal_market_claim": false,
    "terminal_profile": "launch",
    "terminal_claim_scope": "core",
    "terminal_command": "/usr/libexec/propertyquarry/propertyquarry-global-launch-terminal --manifest /run/propertyquarry/release-evidence/global-launch-core-manifest.v1.json",
    "terminal_manifest_schema": "propertyquarry.global_launch_terminal_manifest.v1",
    "terminal_manifest_path": "/run/propertyquarry/release-evidence/global-launch-core-manifest.v1.json",
    "terminal_result_schema": "propertyquarry.global_launch_terminal_result.v1",
    "terminal_installed_bundle_schema": "propertyquarry.global_launch_terminal_bundle.v1",
    "terminal_requires_signed_invocation_contract": true,
    "terminal_required_authorities": [
      "release_preflight",
      "disaster_recovery",
      "capacity",
      "observability_operations",
      "controller_attestation"
    ],
