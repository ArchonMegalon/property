# Local quick-start profile (memory backend)
TZ=Europe/Vienna
EA_HOST_PORT=8090
EA_RESPONSES_PROVIDER_LEDGER_DIR=/data/provider-ledger

# App runtime
EA_APP_NAME=ea-rewrite-local
EA_ROLE=api
EA_RUNTIME_MODE=dev
EA_HOST=0.0.0.0
EA_PORT=8090
EA_LOG_LEVEL=INFO
EA_STORAGE_BACKEND=memory
EA_DEFAULT_PRINCIPAL_ID=local-user
EA_API_TOKEN=
EA_SIGNING_SECRET=replace-with-a-strong-shared-secret
EA_CF_TUNNEL_TOKEN=

# Database (required by compose service, even when using memory backend)
POSTGRES_DB=ea
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local_dev_only
DATABASE_URL=postgresql://postgres:local_dev_only@ea-db:5432/ea

# Optional 1min.AI key rotation (local .env only; keep real keys out of git)
# Recommended once the slot chain gets large: point ONEMIN_DIRECT_API_KEYS_JSON_FILE at
# a gitignored JSON array file such as config/onemin_api_keys.local.json. The runtime
# will merge that manifest with any ONEMIN_AI_API_KEY_FALLBACK_<n> env vars.
